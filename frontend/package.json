{
  "name": "civiksutra-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test e2e/smoke.spec.ts --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:smoke": "npm run typecheck && npm run lint && npm run format:check && vitest run",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "lhci": "lhci autorun",
    "validate": "npm run typecheck && npm run lint && npm run format:check && npm run test:coverage"
  },
  "dependencies": {
    "@react-google-maps/api": "latest",
    "@vitejs/plugin-react": "latest",
    "i18next": "^26.0.8",
    "react": "latest",
    "react-dom": "latest",
    "react-i18next": "^17.0.4",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@eslint/js": "^9.39.4",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@testing-library/user-event": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "latest",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "latest"
  }
}
