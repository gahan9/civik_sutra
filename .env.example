# Election Process Education Assistant - Environment Configuration
# Copy to .env and fill in values. NEVER commit .env to git.

# GCP / Firebase
EP_GCP_PROJECT_ID=your-firebase-project-id
EP_GEMINI_API_KEY=your-gemini-api-key

# CORS (frontend origin)
EP_CORS_ORIGINS=["http://localhost:5173"]

# Rate limits (daily per user)
EP_DAILY_GEMINI_REQUESTS=100
EP_MAX_TOKENS_PER_REQUEST=1024
EP_DAILY_VISION_CALLS=50

# reCAPTCHA v3
EP_RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key
EP_RECAPTCHA_SCORE_THRESHOLD=0.5

# Google Maps Platform (optional -- falls back to cached data)
EP_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Vite exposes only VITE_* variables to the browser build.
VITE_GOOGLE_MAPS_API_KEY=your-browser-restricted-google-maps-api-key
